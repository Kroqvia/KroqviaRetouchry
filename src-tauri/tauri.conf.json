{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KroqviaRetouchry",
  "version": "0.1.0",
  "identifier": "com.kroqvia.retouchry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KroqviaRetouchry",
        "width": 1400,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": []
  }
}
